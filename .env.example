# .env.example — copy to .env and fill in. .env is git-ignored (see .gitignore).
# init.sh sources this file at runtime, so secrets never live in committed code.

# iPhone hotspot password (Path 3 of setup_network).
HOTSPOT_PASS="changeme"

# Optional overrides (defaults shown in init.sh):
# HOTSPOT_SSID="michaels iphone"
# STATIC_IP="172.16.1.14/16"
# STATIC_GW="172.16.0.254"
# STATIC_DNS="168.95.1.1,168.95.192.1"

# Optional: set this to skip the interactive Claude Code key prompt.
# ANTHROPIC_API_KEY="sk-ant-..."
