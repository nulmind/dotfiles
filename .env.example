# .env.example — copy to .env and fill in. .env is git-ignored (see .gitignore).
# init.sh sources this file at runtime, so secrets never live in committed code.

# iPhone hotspot password (Path 3 of setup_network).
HOTSPOT_PASS="changeme"

# Optional overrides (defaults shown in init.sh):
# HOTSPOT_SSID="michaels iphone"
# STATIC_IP="172.16.1.14/16"
# STATIC_GW="172.16.0.254"
# STATIC_DNS="168.95.1.1,168.95.192.1"

# Optional: set this to skip the interactive Claude Code key prompt.
# ANTHROPIC_API_KEY="sk-ant-..."

# ── Local LLM overrides (auto-detected from GPU/RAM if unset) ──
# Override the primary model (auto-selected based on hardware):
#   RTX 3090 (24GB)  → qwen2.5-coder:32b
#   RTX 5090 (32GB)  → qwen3:32b
#   CPU + 80GB RAM   → deepseek-r1:14b
#   CPU + 48GB RAM   → phi4:14b
#   CPU + 14GB RAM   → qwen2.5-coder:7b
#   Fallback         → phi4-mini
# LOCAL_LLM_MODEL="qwen3:32b"

# Override the always-hot router model (used on GPU paths only):
# LOCAL_LLM_ROUTER="qwen2.5:7b"

# Store models on a separate/larger drive (recommended if OS disk < 50GB):
# OLLAMA_MODELS="/mnt/bigdrive/.ollama/models"

# Install CUDA toolkit alongside GPU driver (adds ~5GB):
# INSTALL_CUDA=1

# Skip LLM setup entirely (e.g. tiny boot drive, pull models later):
# SKIP_LLM=1
